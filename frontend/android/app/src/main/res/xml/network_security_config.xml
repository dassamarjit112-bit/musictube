<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Explicitly allow cleartext for Local Development & API fallbacks -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        
        <!-- Known Google/YouTube Streaming Domains -->
        <domain includeSubdomains="true">googlevideo.com</domain>
        <domain includeSubdomains="true">youtube.com</domain>
        <domain includeSubdomains="true">ytimg.com</domain>
        <domain includeSubdomains="true">s.ytimg.com</domain>
        <domain includeSubdomains="true">www.youtube.com</domain>
    </domain-config>

    <!-- Global configuration for all other domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
